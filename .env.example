# PDFMount Environment Variables Example
# Copy this file to .env in production and local development

# -----------------
# Service Ports
# -----------------
# Host and port that the Rust Axum API will bind to
PORT=8081
HOST=127.0.0.1

# -----------------
# Storage Directories
# -----------------
# Directory where database files, temp uploads, and processed outputs are stored
PDFMOUNT_WORK_DIR=./data

# -----------------
# Backend Config
# -----------------
# Path to the Python binary processor (use python3 on production linux)
PYTHON_BIN=python3

# -----------------
# Supabase Configuration (Frontend auth verification)
# -----------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here

# -----------------
# Stripe Configuration (Secure Subscription Checkout)
# -----------------
# Secret key used to authorize checkout session creations
STRIPE_SECRET_KEY=sk_test_51...
# Secret webhook signing token used to verify event payloads
STRIPE_WEBHOOK_SECRET=whsec_...
# Redirection page on success/cancel
CLIENT_REDIRECT_URL=https://gharvanta.in/pricing
